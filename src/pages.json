{
	"easycom": {
		"autoscan": true,
		"custom": {
			"^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
		}
	},
	"pages": [
		{
			"path": "pages/home/index"
		},
		{
			"path": "pages/room/index"
		},
		{
			"path": "pages/settlement/index"
		},
		{
			"path": "pages/manual/index"
		}
	],
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "打牌好友记账",
		"navigationBarBackgroundColor": "#ffffff",
		"backgroundColor": "#ffffff"
	},
	"tabBar": {
		"color": "#bfbfbf",
		"selectedColor": "#1296db",
		"borderStyle": "black",
		"backgroundColor": "#ffffff",
		"list": [
			{
				"pagePath": "pages/home/index",
				"text": "首页",
				"iconPath": "/static/images/tabbar/home1.png",
				"selectedIconPath": "/static/images/tabbar/home2.png"
			},
			{
				"pagePath": "pages/room/index",
				"text": "房间",
				"iconPath": "/static/images/tabbar/pinia1.png",
				"selectedIconPath": "/static/images/tabbar/pinia2.png"
			},
			{
				"pagePath": "pages/settlement/index",
				"text": "结算",
				"iconPath": "/static/images/tabbar/charts1.png",
				"selectedIconPath": "/static/images/tabbar/charts2.png"
			}
		]
	}
}
